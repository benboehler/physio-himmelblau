---
import angebot1 from '../../assets/angebot1.jpg';
import angebot2 from '../../assets/angebot2.jpg';
import angebot3 from '../../assets/angebot3.jpg';
import ImageCard from '../ui/ImageCard.astro';
---

<div class="flex justify-center items-center mt-12 mb-4">
    <h1 class="text-4xl">angebot</h1>
</div>
<div class="grid grid-cols-12 gap-4 mb-20">
    <div class="col-span-12 md:col-span-4">
        <ImageCard src={angebot1.src} alt="Angebot 1" text="Angebot 1" />
    </div>
    <div class="col-span-12 md:col-span-4">
        <ImageCard src={angebot2.src} alt="Angebot 2" text="Angebot 2" />
    </div>
    <div class="col-span-12 md:col-span-4">
        <ImageCard src={angebot3.src} alt="Angebot 3" text="Angebot 3" />
    </div>
</div>
