---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import AnimateOnScroll from "../components/ui/AnimateOnScroll.astro";
import BackgroundHimmelblau from "../components/ui/BackgroundHimmelblau.astro";
const {title = "physio himmelblau"} = Astro.props;
---

<!doctype html>
<html lang="de">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/svg+xml" href="/faviconC.svg"/>
    <link rel="icon" href="/faviconC.ico"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <meta name="generator" content={Astro.generator}/>
    <title>{title}</title>
</head>
<body>
<Header/>
<BackgroundHimmelblau/>
<slot/>
<Footer/>
<AnimateOnScroll/>
</body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        scroll-behavior: smooth;
    }
</style>