---
import Header from "../components/Header.astro";
import "../styles/global.css";
const {title = "physio himmelblau"} = Astro.props;
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width"/>
        <link rel="icon" type="image/svg+xml" href="/faviconC.svg"/>
        <link rel="icon" href="/faviconC.ico"/>
        <meta name="generator" content={Astro.generator}/>
        <title>{title}</title>
    </head>
    <body>
        <slot/>
        <Header/>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>